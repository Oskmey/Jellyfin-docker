# Copy this file to .env and update the values.
# The setup script can create .env for you: ./scripts/setup.sh

# Base path for persistent data.
# Relative paths are resolved from the repository root.
COMMON_PATH=./data

# Container runtime settings
TZ=UTC
PUID=1000
PGID=1000

# Public nginx port on the host
NGINX_PORT=8090

# Optional nginx bind IP on the host.
# Keep 0.0.0.0 to listen on all host interfaces, or set a specific LAN/loopback IP.
NGINX_BIND_IP=0.0.0.0

# Public Jellyseerr port on the host (direct, not proxied by nginx)
JELLYSEERR_PORT=5055

# Optional Jellyseerr bind IP on the host.
# Keep 0.0.0.0 to listen on all host interfaces, or set a specific LAN/loopback IP.
JELLYSEERR_BIND_IP=0.0.0.0

# Public Jellyseerr URL used by the Homepage dashboard card.
# Replace localhost with the host or DNS name your browser uses to reach the stack.
JELLYSEERR_EXTERNAL_URL=http://localhost:5055

# Optional networking defaults
DNS=1.1.1.1
DNS_SECONDARY=1.0.0.1
SERVER_COUNTRIES=Sweden

# Required Mullvad WireGuard settings
WIREGUARD_ADDRESSES=
WIREGUARD_PRIVATE_KEY=
WIREGUARD_PUBLIC_KEY=
WIREGUARD_ENDPOINT=
WIREGUARD_ALLOWED_IPS=0.0.0.0/0,::/0

# Homepage host validation allowlist.
# Use comma-separated host[:port] values (or "*" for local-only setups).
HOMEPAGE_ALLOWED_HOSTS=*
